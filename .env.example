# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@hostname.railway.app:PORT/database?sslmode=require

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payphone (Ecuador Payments)
PAYPHONE_APP_KEY=your-payphone-app-key
PAYPHONE_APP_SECRET=your-payphone-app-secret
PAYPHONE_ENVIRONMENT=sandbox
NEXT_PUBLIC_PAYPHONE_CLIENT_ID=your-payphone-client-id